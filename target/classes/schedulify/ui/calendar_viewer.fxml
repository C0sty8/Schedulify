<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.SubScene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="609.5" style="-fx-background-color: #EAEFEF;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="schedulify.ui.CalendarViewerController">
   <children>
      <VBox prefHeight="400.0" prefWidth="159.0" spacing="3.0" style="-fx-background-color: white;">
         <children>
            <Button mnemonicParsing="false" onAction="#backToMainScene" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="Back">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#onSettings" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="Settings">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#onViewSchedule" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="View Schedule">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="editScheduleButton" mnemonicParsing="false" onAction="#onEditSchedule" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="Edit Schedule">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="editEventsButton" mnemonicParsing="false" onAction="#onEditEvents" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="Edit Events">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="addActivitiesButton" layoutX="10.0" layoutY="173.0" mnemonicParsing="false" onAction="#onAddActivity" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="Add Activities">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="addEventsButton" layoutX="10.0" layoutY="200.0" mnemonicParsing="false" onAction="#onAddEvent" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="Add Events">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="suggestedEventsButton" layoutX="10.0" layoutY="173.0" mnemonicParsing="false" onAction="#onSuggestedEvents" prefHeight="26.0" prefWidth="169.0" style="-fx-background-color: #BFC6C4;" text="SUGGESTED EVENTS">
               <font>
                  <Font name="Microsoft Tai Le Bold" size="12.0" />
               </font>
            </Button>
         </children>
      </VBox>
      <SubScene fx:id="viewer" height="400.0" layoutX="159.0" width="450.0">
         <root>
            <Region />
         </root>
      </SubScene>
   </children>
</AnchorPane>
